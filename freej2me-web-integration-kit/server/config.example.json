{
  "comment": "Example config for FreeJ2ME Web Bridge integration kit. Paths are relative to this server.js folder unless absolute.",
  "javaPath": "../jdk8u492-b09-jre/bin/java.exe",
  "freej2meJar": "../freej2me-plus",
  "port": 3000,
  "width": 320,
  "height": 240,
  "rotate": 0,
  "phoneType": 0,
  "sound": 1,
  "targetFps": 30,
  "maxFps": 30,
  "streamScale": 1,
  "imageQuality": 65,
  "videoCodec": "webp",
  "wsCompression": false,
  "audioPipe": true,
  "maxActiveSessions": 8,
  "sessionIdleMs": 600000,
  "webpQuality": 55,
  "webpEffort": 0,
  "audioCodec": "opus",
  "opusBitrate": "64k",
  "ffmpegPath": "./tools/ffmpeg.exe on Windows or ffmpeg on Linux PATH",
  "audioPacketMs": 60,
  "maxUploadMb": 50,
  "maxUserStorageMb": 500,
  "maxTotalStorageMb": 0,
  "uploadRetentionHours": 24,
  "tempRetentionHours": 6,
  "cleanupIntervalMs": 600000,
  "noClientShutdownMs": 5000,
  "sessionPolicy": "single",
  "startConcurrency": 1,
  "queueMaxSize": 16
}